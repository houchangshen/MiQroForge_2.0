# ── 软件安装包（BYOB：用户自行提供，不入库）────────────────────────────────
# ORCA 及其他计算软件的 tarball，体积大且受许可协议限制，不得入库
nodes/base_images/**/*.tar.xz
nodes/base_images/**/*.tar.gz
nodes/base_images/**/*.tar.bz2
nodes/base_images/**/*.zip
nodes/base_images/**/*.tbJ

# ── 生成产物（运行时生成，不入库）──────────────────────────────────────────
